# Ensure consistent line endings and encoding across platforms
* text=auto

# Force LF line endings for JSON files
*.json text eol=lf

# Force LF for YAML files
*.yaml text eol=lf
*.yml text eol=lf

# Force LF for Python files
*.py text eol=lf

# Force LF for JavaScript files
*.js text eol=lf
*.ts text eol=lf

# Force LF for Markdown
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
